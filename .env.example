# Copy to .env.local and fill in real values. On Vercel, add these under
# Project → Settings → Environment Variables.

# Password for the owner dashboard at /admin
ADMIN_PASSWORD=

# Paystack secret key (Dashboard → Settings → API Keys & Webhooks)
PAYSTACK_SECRET_KEY=

# Supabase (project → Settings → API). Run supabase/schema.sql first.
# Service-role key is SERVER-ONLY — never expose it in client code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (resend.com → API Keys) — automatic product delivery emails.
# Optional RESEND_FROM once you verify your own domain in Resend.
RESEND_API_KEY=
# RESEND_FROM="Blaze Digital Hub <hello@yourdomain.com>"
