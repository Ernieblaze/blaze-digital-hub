# Copy to .env.local and fill in real values. On Vercel, add these under
# Project → Settings → Environment Variables.

# Password for the owner dashboard at /admin
ADMIN_PASSWORD=

# Paystack secret key (Dashboard → Settings → API Keys & Webhooks)
PAYSTACK_SECRET_KEY=

# Supabase (project → Settings → API). Run supabase/schema.sql first.
# Service-role key is SERVER-ONLY — never expose it in client code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Brevo (SMTP & API → API Keys) — delivery emails + buyer login codes.
# Sender must be a verified sender in Brevo (Senders & IPs → Senders).
BREVO_API_KEY=
# BREVO_FROM_EMAIL=you@example.com
# BREVO_FROM_NAME="Blaze Digital Hub"
# Optional: Brevo list number to add newsletter signups to
# BREVO_LIST_ID=2

# Google sign-in (console.cloud.google.com → Credentials → OAuth client ID).
# Authorized redirect URI: <site-url>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated Google emails allowed to open /admin via "Continue with
# Google (owner)". Password login keeps working regardless.
ADMIN_EMAILS=
